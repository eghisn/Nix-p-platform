{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "functions": {
    "api/finance-app.js": {
      "includeFiles": "apps/finance/index.html"
    }
  },
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "admin.nix-p.com" }],
      "destination": "/admin",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "finance.nix-p.com" }],
      "destination": "/finance",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/payments/midtrans-token",
      "destination": "/api/checkout?commerceAction=midtrans-token"
    },
    {
      "source": "/api/webhooks/midtrans",
      "destination": "/api/checkout?commerceAction=midtrans-webhook"
    },
    {
      "source": "/api/admin/orders",
      "destination": "/api/admin/store?commerceAction=orders"
    },
    {
      "source": "/login",
      "has": [{ "type": "host", "value": "finance.nix-p.com" }],
      "destination": "/api/finance-app?financePath=/login"
    },
    {
      "source": "/logout",
      "has": [{ "type": "host", "value": "finance.nix-p.com" }],
      "destination": "/api/finance-app?financePath=/logout"
    },
    {
      "source": "/finance",
      "has": [{ "type": "host", "value": "finance.nix-p.com" }],
      "destination": "/api/finance-app?financePath=/"
    },
    {
      "source": "/index.html",
      "has": [{ "type": "host", "value": "finance.nix-p.com" }],
      "destination": "/api/finance-app?financePath=/"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
